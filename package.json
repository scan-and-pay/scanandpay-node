{
  "name": "@scanandpay/node",
  "version": "0.2.2",
  "description": "Official Scan & Pay Node.js SDK — accept PayTo PayID payments via QR.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "require": "./dist/react/index.js",
      "import": "./dist/react/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "payments",
    "payto",
    "payid",
    "scanandpay",
    "australia",
    "npp"
  ],
  "author": "SENAX Enterprises Pty Ltd",
  "license": "Apache-2.0",
  "homepage": "https://docs.scanandpay.com.au/sdks/node",
  "repository": {
    "type": "git",
    "url": "https://github.com/scan-and-pay/scanandpay-node.git"
  },
  "bugs": {
    "url": "https://github.com/scan-and-pay/scanandpay-node/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
